# Clerk publishable key for the React app.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"

# Clerk publishable key for the Express API middleware.
CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"

# Clerk secret key for the Express API.
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key"

# Neon Postgres connection strings used by Prisma.
DATABASE_URL="postgresql://user:password@pooled-host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@direct-host/db?sslmode=require"

# Local API server port.
PORT="4000"

# Allowed frontend origin for local development.
CORS_ORIGIN="http://localhost:3000"

# Optional Passio system override for Bull Runner.
PASSIO_SYSTEM_ID="2343"

# OpenRouteService API key for shortest-path walking directions.
OPENROUTESERVICE_API_KEY=""

# Optional override when the API is hosted on a different origin.
VITE_API_BASE_URL=""
